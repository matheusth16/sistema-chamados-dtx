# Evita enviar arquivos desnecessários ao Cloud Build (build mais rápido e previsível)
# Baseado no .gitignore + itens extras para deploy

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Ambiente virtual
.venv/
venv/
env/

# Segredos e config local (NUNCA enviar ao build)
.env
.env.*
!.env.example
credentials.json

# Logs e DB local
logs/
*.log
*.db
instance/

# Uploads (dados de usuário, não código)
app/static/uploads/*
!app/static/uploads/.gitkeep

# SO
.DS_Store
Thumbs.db

# Testes (não precisam ir para o build de produção)
tests/
.pytest_cache/
coverage.xml
htmlcov/

# Scripts de diagnóstico e dev (não são parte da app)
scripts/

# CI/CD e ferramentas de dev
.github/
.pre-commit-config.yaml
ruff.toml
requirements-dev.txt

# Documentação local
*.md
!README.md
