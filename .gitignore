# --- Node ---
node_modules/

# --- Python ---
__pycache__/
*.py[cod]
*.pyc
*$py.class
.pytest_cache/
.coverage
htmlcov/
.coverage.*
coverage.xml
coverage.json
.mypy_cache/
.ruff_cache/
*.egg-info/
*.egg
dist/
build/

# --- Artefatos de build CSS (gerado por npm run build:css e pelo Dockerfile) ---
# Não versionar: o Dockerfile regenera no build; dev local usa npm run build:css
app/static/css/tailwind.min.css

# --- Artefatos de build (bundle SPA experimental, não usado pelos templates) ---
app/static/dist/

# --- Ambiente Virtual ---
.venv/
venv/
env/

# --- Segredos e Configurações ---
.env
.env.local
.env.*.local
credentials.json
*.pem
*.key

# --- Logs ---
logs/
*.log

# --- Banco de Dados ---
# Ignoramos o arquivo do banco para que os dados de teste fiquem só no seu PC
*.db
instance/

# --- Uploads (Dados do Usuário) ---
# Muito importante: não queremos subir fotos/PDFs de teste para o código
app/static/uploads/*
# Mas queremos manter a pasta vazia no repositório (opcional)
!app/static/uploads/.gitkeep

# --- Firebase (emulador/debug) ---
firebase-debug.log
firestore-debug.log
ui-debug.log
database-debug.log

# --- Sistema Operacional ---
.DS_Store
Thumbs.db
*.swp
*~

# --- IDE / Editor ---
.idea/
.vscode/
*.sublime-*

# --- Backups e temporários ---
*.bak
*.tmp
.ipynb_checkpoints/
tmp/

# --- Checkpoints locais de migração (artefatos de execução, não versionados) ---
scripts/.checkpoints/

# --- Backup de arquivos não utilizados (análise de código morto) ---
_backup_nao_utilizados/

# --- Ferramentas de IA / Editor ---
.claude/
.cursor/

# --- Arquivos locais de trabalho (não versionados) ---
*.docx
foto/
