# .env.test.example — Copie para .env.test e preencha com credenciais de teste
# NUNCA commite .env.test com valores reais

# URL do servidor Flask para testes E2E
# Local:  http://127.0.0.1:5000
# CI/CD:  configurar como secret FLASK_TEST_URL no GitHub
FLASK_TEST_URL=http://127.0.0.1:5000

# Credenciais de teste por perfil
# Crie usuários de teste dedicados no ambiente de desenvolvimento/staging
# Não use credenciais de produção

TEST_SOLICITANTE_EMAIL=solicitante_teste@empresa.com
TEST_SOLICITANTE_PASSWORD=senha_de_teste_aqui

TEST_SUPERVISOR_EMAIL=supervisor_teste@empresa.com
TEST_SUPERVISOR_PASSWORD=senha_de_teste_aqui

TEST_ADMIN_EMAIL=admin_teste@empresa.com
TEST_ADMIN_PASSWORD=senha_de_teste_aqui

# Usado apenas por tests/e2e/test_capture_onboarding_screenshots.py (captura de
# screenshots do onboarding). Aponte para o usuário admin_global criado por
# scripts/seed_dados_demo_onboarding.py (demo.admin.global@dtx.com).
TEST_ADMIN_GLOBAL_EMAIL=demo.admin.global@dtx.com
TEST_ADMIN_GLOBAL_PASSWORD=DemoOnboarding123!
