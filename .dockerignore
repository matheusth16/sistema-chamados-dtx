# Controle de versão
.git
.gitignore

# Ambientes virtuais
.venv/
venv/
env/

# Python compilado
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Banco local e uploads
*.db
instance/
app/static/uploads/*
!app/static/uploads/.gitkeep

# Segredos (NUNCA no build context)
.env
.env.*
credentials.json
*.pem
*.key

# Testes (não vão para produção)
tests/
coverage.xml
coverage.json
htmlcov/
.coverage
test-results-qa/
tmp/

# Ferramentas de desenvolvimento
requirements-dev.txt
ruff.toml
.pre-commit-config.yaml
pytest.ini

# CI/CD e documentação
.github/
*.md
!README.md

# Scripts locais
scripts/

# Node
node_modules/

# Logs e temporários
logs/
*.log
.DS_Store
Thumbs.db

# Firebase (emulador local)
.firebaserc
firebase.json
firebase-debug.log
firestore-debug.log

# IDE
.vscode/
.idea/
.cursor/

# Ferramentas de IA/design (cache local pode conter caminhos da máquina)
.impeccable/
