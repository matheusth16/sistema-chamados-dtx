# Copie para .env e preencha os valores.
# cp .env.example .env

# === Aplicação ===
FLASK_APP=run.py
FLASK_ENV=development
# Obrigatório em produção: gere uma chave forte (ex: openssl rand -hex 32). Não use o valor de desenvolvimento.
SECRET_KEY=gere-uma-chave-secreta-forte-aqui
# URL base usada em links de e-mail e validação de Origin. Em produção deve ser https://.
APP_BASE_URL=http://localhost:5000

# === Firebase ===
# Coloque o arquivo credentials.json na raiz do projeto (não versionado).
# Baixe em: Firebase Console > Configurações do projeto > Contas de serviço.
# No container Docker, monte o arquivo via volume (ver docker-compose.yml).
#
# Anexos: o sistema usa Cloudflare R2 (preferencial) com fallback Firebase Storage.
# Para o fallback, defina FIREBASE_STORAGE_BUCKET com o nome EXATO do bucket
# em Firebase Console > Storage (ex.: gs://projeto.firebasestorage.app → projeto.firebasestorage.app).
# FIREBASE_STORAGE_BUCKET=

# === Cloudflare R2 (storage de anexos — preferencial) ===
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# === E-mail via Microsoft Graph API ===
# Requer app registration no Azure AD com permissão Mail.Send (Application).
# Tenant ID e Client ID: Azure > App Registrations > Overview.
# Client Secret: App Registrations > Certificates & secrets > Client secrets
#   ⚠️  Use o campo "Value" (ex: dad8Q~...), NÃO o "Secret ID" (UUID).
GRAPH_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GRAPH_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GRAPH_CLIENT_SECRET=seu-client-secret-value-aqui
GRAPH_SENDER_EMAIL=xxxxxx.xxxxxx@xxx.xxx

# Ativa e-mail ao solicitante quando status muda para Em Atendimento ou Concluído (opt-in)
# NOTIFY_SOLICITANTE_EMAIL=false

# === Web Push (notificações no navegador) ===
# Gere com: python scripts/gerar_vapid_keys.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# === Criptografia em repouso (LGPD — Onda 4) ===
# Criptografia Fernet dos campos PII 'nome' e 'email' no Firestore (CWI 2.3).
# Default: ENCRYPT_PII_AT_REST=false — zero breaking change até ops ativar.
#
# Para ativar:
#   1. Gere a chave:  python scripts/gerar_chave_criptografia.py
#   2. Crie índice Firestore em email_lookup_hash (single-field) ANTES de migrar
#   3. Rode dry-run:  python scripts/migrar_pii_criptografia.py
#   4. Aplique:       python scripts/migrar_pii_criptografia.py --apply
#   5. Smoke test:    tente login com um usuário migrado
#
# Em produção com ENCRYPT_PII_AT_REST=true: a app não sobe sem ENCRYPTION_KEY válida.
# Ver ADR: docs/adr/001-criptografia-pii-fernet.md
#
# ENCRYPTION_KEY=
# ENCRYPT_PII_AT_REST=false

# === Rate Limiting (relatórios e export) ===
# 0 = desativado. Recomendado em produção: 10.
# RELATORIO_MAX_POR_USUARIO_POR_DIA=10
# EXPORT_EXCEL_MAX_POR_USUARIO_POR_DIA=10

# === Cache e Rate Limiting HTTP (opcional) ===
# Se definido: cache de relatórios e rate limiting compartilhado entre workers (recomendado em produção).
# Senão: cache e rate limit em memória por processo.
# REDIS_URL=redis://localhost:6379/0

# === Tradução (opcional) ===
# Aumenta o limite da MyMemory API de 5k para 10k chars/dia.
# Cadastre-se em mymemory.translated.net
# MYMEMORY_EMAIL=seu@email.com

# === Logging (opcional) ===
# Nível: DEBUG, INFO, WARNING, ERROR. Em produção use INFO ou WARNING.
# LOG_LEVEL=INFO
# LOG_MAX_BYTES=2097152
# LOG_BACKUP_COUNT=5

# === Segurança (produção) ===
SESSION_COOKIE_SECURE=False

# ⚠️  OBRIGATÓRIO EM PRODUÇÃO (a aplicação não sobe sem estas vars quando FLASK_ENV=production)
# Token para proteger /health?deep=1 (expõe status de Firestore e Redis).
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Mínimo 16 caracteres. (ver ADR: docs/adr/003-fail-fast-config-producao.md)
#
# Canal primário (recomendado — não aparece em access logs):
#   curl -H "X-Health-Token: <valor>" "https://host/health?deep=1"
#
# HEALTH_SECRET=

# === Workers e Redis ===
# Número de workers Gunicorn. Padrão: 1 (cenário DTX atual — 1 worker, 8 threads gthread).
# Se GUNICORN_WORKERS > 1, REDIS_URL torna-se obrigatória (rate limit compartilhado).
# GUNICORN_WORKERS=1

# Se true, força fail-fast na boot se REDIS_URL não estiver definida (opt-in explícito).
# REQUIRE_REDIS=false

# === Proteção de ambiente staging/HML (CWI 4.1 — camada 2 fallback) ===
# Ativa HTTP Basic Auth quando ENV != production e TESTING != True.
# Camada primária: VPN / firewall de rede (ver docs/adr/002-protecao-ambientes-staging.md).
# NÃO ativar em produção: STAGING_AUTH_ENABLED é ignorado quando ENV=production.
# NÃO ativar em desenvolvimento sem HTTPS configurado (Basic Auth transmite em Base64).
# Rotas excluídas automaticamente: /health, /login, /sw.js
#
# Gere credenciais fortes:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# STAGING_AUTH_ENABLED=true
# STAGING_AUTH_USER=hml_user
# STAGING_AUTH_PASSWORD=gere-senha-forte-aqui

# === SLA / Escalonamento ===
# Janela de tempo útil DTX (seg–sex, pausa almoço)
# SLA_HORARIO_INICIO=07:00
# SLA_HORARIO_FIM=16:30
# SLA_ALMOCO_INICIO=11:30
# SLA_ALMOCO_FIM=13:00
# Prazo de resolução por categoria (dias úteis)
# SLA_DIAS_RESOLUCAO_PROJETOS=2
# SLA_DIAS_RESOLUCAO_PADRAO=3
# Incluir sábado/domingo no cálculo de tempo útil (false = excluir, v1)
# SLA_INCLUI_FIM_DE_SEMANA=false
# Timezone para cálculos SLA (IANA tz name)
# SLA_TIMEZONE=America/Sao_Paulo
# E-mails dos gestores por nível — Fase 6 (escalada gerencial)
# Formato JSON: chave = nivel_gestao, valor = e-mail
# GESTOR_EMAILS={"gestor_setor":"gestor@dtx.aero","gerente_producao":"gerente@dtx.aero","assistente_gm":"ass.gm@dtx.aero","gm":"gm@dtx.aero"}
