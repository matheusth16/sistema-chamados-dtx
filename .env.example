# Copie para .env e preencha os valores.
# cp .env.example .env

# === Aplicação ===
FLASK_APP=run.py
FLASK_ENV=development
# Obrigatório em produção: gere uma chave forte (ex: openssl rand -hex 32). Não use o valor de desenvolvimento.
SECRET_KEY=gere-uma-chave-secreta-forte-aqui

# Opcional: banco SQL (não usado pelo Firestore; pode remover)
DATABASE_URL=sqlite:///chamados.db

# === Firebase ===
# Coloque o arquivo credentials.json na raiz do projeto (não versionado).
# Baixe em: Firebase Console > Configurações do projeto > Contas de serviço.
#
# OBRIGATÓRIO EM PRODUÇÃO (Cloud Run): FIREBASE_STORAGE_BUCKET para anexos.
# Use o nome EXATO do bucket em Firebase Console > Storage (ex.: gs://projeto.firebasestorage.app → projeto.firebasestorage.app).
# Projetos novos usam .firebasestorage.app; antigos podem usar .appspot.com.
# 1) Defina: FIREBASE_STORAGE_BUCKET=seu-projeto.firebasestorage.app
# 2) No GCP: conta de serviço do Cloud Run com permissão "Storage Object Admin" no bucket.
# FIREBASE_STORAGE_BUCKET=

# === URL base (para links em e-mails e notificações) ===
APP_BASE_URL=https://seu-dominio.com

# === E-mail (SMTP - notificações ao supervisor) ===
# O sistema envia para o e-mail do supervisor; o REMETENTE é o que você configurar abaixo.
# Envio pelo seu e-mail pessoal: use SOMENTE as variáveis MAIL_* (ex.: Gmail) e NÃO defina RESEND_API_KEY.
MAIL_SERVER=smtp.office365.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=seu-email@empresa.com
MAIL_PASSWORD=sua-senha-app
MAIL_DEFAULT_SENDER=seu-email@empresa.com

# --- Teste com e-mail pessoal (remetente = seu Gmail) ---
# 1) Ative "Senha de app" em https://myaccount.google.com/apppasswords
# 2) Preencha abaixo com seu Gmail e a senha de app. Deixe RESEND_API_KEY vazio (ou comente).
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=seu.email.pessoal@gmail.com
# MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
# MAIL_DEFAULT_SENDER=Seu Nome <seu.email.pessoal@gmail.com>

# === Microsoft Teams (webhook - notificações) ===
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# === Web Push (notificações no navegador) ===
# Gere com: python scripts/gerar_vapid_keys.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# === Cache e Rate Limiting (opcional) ===
# Se definido: cache de relatórios e rate limiting compartilhado entre workers (recomendado em produção).
# Senão: cache e rate limit em memória por processo.
# REDIS_URL=redis://localhost:6379/0

# === Logging (opcional) ===
# Nível: DEBUG, INFO, WARNING, ERROR. Em produção use INFO ou WARNING.
# LOG_LEVEL=INFO
# Rotação do arquivo de log (padrão: 2MB por arquivo, 5 backups)
# LOG_MAX_BYTES=2097152
# LOG_BACKUP_COUNT=5

# === Segurança (produção) ===
# SESSION_COOKIE_SECURE=True

# === Criptografia em repouso (LGPD) ===
# Gere com: python scripts/gerar_chave_criptografia.py
# Se definida + ENCRYPT_PII_AT_REST=true, o campo 'nome' em usuarios é criptografado no Firestore.
# ENCRYPTION_KEY=
# ENCRYPT_PII_AT_REST=false

# === Resend (e-mail transacional - opcional) ===
# Se RESEND_API_KEY estiver definido, o sistema usa Resend em vez de SMTP.
# Para envio pelo seu e-mail pessoal (SMTP): NÃO defina RESEND_API_KEY; use somente MAIL_* acima.
# RESEND_API_KEY=
# Remetente (padrão: domínio de teste da Resend)
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Sistema de Chamados